{
  "buildCommand": "npm run build && npm run web:build",
  "outputDirectory": "public",
  "regions": ["fra1"],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}